{
  "name": "website-monitor-agent",
  "version": "4.1.0",
  "description": "AI-powered website change monitor using Playwright + Gemini + Discord",
  "workspaces": [
    "plugins/*"
  ],
  "scripts": {
    "start": "concurrently -n api,ui,mon,bot -c cyan,magenta,yellow,blue \"tsx --watch src/agent.ts --apiPort 3001\" \"npm run ui:dev\" \"tsx src/health-monitor.ts --apiPort 3001\" \"tsx src/discord-bot.ts --apiPort 3001\"",
    "stop": "node scripts/stop.mjs",
    "restart": "npm stop && npm start",
    "monitor": "tsx src/health-monitor.ts --apiPort 3001",
    "bot": "tsx src/discord-bot.ts --apiPort 3001",
    "dev": "tsx --watch src/agent.ts",
    "api": "tsx src/agent.ts --apiPort 3001",
    "api:dev": "tsx --watch src/agent.ts --apiPort 3001",
    "watch-browser": "tsx src/agent.ts --runOnce --browserHeadless=false --browserSlowMoMs 250 --browserKeepOpenMs 5000",
    "debug:once": "tsx src/agent.ts --runOnce --browserHeadless=false --browserSlowMoMs 250",
    "debug": "tsx src/agent.ts --apiPort 3001 --browserHeadless=false --browserSlowMoMs 250",
    "test:hermes": "tsx scripts/test-hermes-simple.ts",
    "browser_mode": "tsx src/agent.ts --browserPersistSession --browserHeadless=false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "ui:dev": "cd client && npm run dev",
    "ui:prod": "cd client && npm run build",
    "ui:typecheck": "cd client && npm run typecheck",
    "dev:all": "concurrently -n api,ui -c cyan,magenta \"npm run api:dev\" \"npm run ui:dev\"",
    "postinstall": "npm install --prefix client",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@google/genai": "^2.6.0",
    "@webtracker/plugin-hermes": "file:plugins/hermes",
    "cors": "^2.8.6",
    "diff": "^9.0.0",
    "discord.js": "^14.26.4",
    "express": "^5.2.1",
    "groq-sdk": "^1.2.0",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "supertest": "^7.2.2",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.7"
  }
}
