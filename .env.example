# ── LLM: Gemini ──────────────────────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
LLM_GEMINI_ENABLED=true
LLM_GEMINI_PRIORITY=1
LLM_GEMINI_MODEL=gemini-2.5-flash
LLM_GEMINI_TIMEOUT_MS=30000
LLM_GEMINI_MAX_RETRIES=1

# ── LLM: Groq (failover) ─────────────────────────────────────────────────────
# Get a free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
LLM_GROQ_ENABLED=false
LLM_GROQ_PRIORITY=2
LLM_GROQ_MODEL=llama-3.3-70b-versatile
LLM_GROQ_TIMEOUT_MS=30000
LLM_GROQ_MAX_RETRIES=1

# ── Notifications ─────────────────────────────────────────────────────────────
# Create a webhook in Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ── Target page ───────────────────────────────────────────────────────────────
# The page you want to monitor
TARGET_URL=https://example.com
# Optional: CSS selector to target a specific section (e.g. "main", "#prices", ".hero")
TARGET_SELECTOR=

# ── Scheduler ─────────────────────────────────────────────────────────────────
# How often to check for changes, in milliseconds (default: 5 minutes)
CHECK_INTERVAL_MS=300000
# Set to true to run once and exit (useful for cron / Task Scheduler)
RUN_ONCE=false

# ── API server (Week 2+) ──────────────────────────────────────────────────────
# Set a port to start the REST API server alongside (or instead of) the CLI loop.
# When set, the monitor is NOT auto-started; use POST /api/monitor/start via the UI.
# Unset or 0 = classic CLI-only mode (backward-compatible).
API_PORT=3001

# ── Browser ───────────────────────────────────────────────────────────────────
BROWSER_HEADLESS=true
BROWSER_PERSIST_SESSION=true
BROWSER_USER_DATA_DIR=.browser-profile
BROWSER_GOTO_TIMEOUT_MS=60000
BROWSER_SLOW_MO_MS=0
BROWSER_KEEP_OPEN_MS=0

# ── Manual-assisted login (for sites with bot protection) ─────────────────────
MANUAL_ASSISTED=false
MANUAL_ASSISTED_INITIAL_WAIT_MS=120000
